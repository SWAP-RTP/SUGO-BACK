{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "rootDir": ".",
    "outDir": "./dist",
    "types": ["node"],
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true
  },
  "include": ["src", "index.ts"],
  "exclude": ["node_modules"]
}
